{
  "models": [
    {
      "id": "page-metadata",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "jcr:title",
          "label": "Title"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "jcr:description",
          "label": "Description"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "keywords",
          "multi": true,
          "label": "Keywords"
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "template",
          "label": "Page Template",
          "description": "Controls the page layout and loads template-specific styles",
          "options": [
            { "name": "Default", "value": "" },
            { "name": "Article / Blog Post", "value": "article" },
            { "name": "Landing Page (no header/footer)", "value": "landing" }
          ]
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "og:image",
          "label": "Social Share Image",
          "description": "Image shown when this page is shared on social media (OG Image)"
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "robots",
          "label": "Search Engine Indexing",
          "description": "Controls whether search engines index this page",
          "options": [
            { "name": "Index & Follow (default)", "value": "" },
            { "name": "No Index", "value": "noindex" },
            { "name": "No Follow", "value": "nofollow" },
            { "name": "No Index, No Follow", "value": "noindex, nofollow" }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "canonical",
          "label": "Canonical URL",
          "description": "Override the canonical URL for this page (leave blank to use page URL)"
        }
      ]
    }
  ]
}