        "multi": true,
        "label": "Keywords"
      },
      {
        "component": "select",
        "valueType": "string",
        "name": "template",
        "label": "Page Template",
        "description": "Controls the page layout and loads template-specific styles",
        "options": [
          {
            "name": "Default",
            "value": ""
          },
          {
            "name": "Article / Blog Post",
            "value": "article"
          },
          {
            "name": "Landing Page (no header/footer)",
            "value": "landing"
          },
          {
            "name": "Russell Article (EDS Demo)",
            "value": "russell-article"
          },
          {
            "name": "Blog Post",
            "value": "blog"
          }
        ]
      },
      {
        "component": "reference",
        "valueType": "string",
        "name": "og:image",
        "label": "Social Share Image",
        "description": "Image shown when this page is shared on social media (OG Image)"
      },
      {
        "component": "select",
        "valueType": "string",
        "name": "robots",
        "label": "Search Engine Indexing",
        "description": "Controls whether search engines index this page",
        "options": [
          {
            "name": "Index & Follow (default)",
            "value": ""
          },
          {
            "name": "No Index",
            "value": "noindex"
          },
          {
            "name": "No Follow",
            "value": "nofollow"
          },
          {
            "name": "No Index, No Follow",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "component": "text",
        "valueType": "string",
        "name": "canonical",
        "label": "Canonical URL",
        "description": "Override the canonical URL for this page (leave blank to use page URL)"
      },
      {
        "component": "text",
        "valueType": "string",
        "name": "experiment",
        "label": "A/B Experiment ID",
        "description": "Assign this page to an A/B test (e.g. hero-cta-test). Visitors are randomly split 50/50 between control and variant-a."
      },
      {
        "component": "text",
        "valueType": "string",
        "name": "experiment-variant",
        "label": "Force Experiment Variant (QA)",
        "description": "Pin a specific variant for QA/preview. Leave blank for random assignment.",
        "options": [
          {
            "name": "Random (default)",
            "value": ""
          },
          {
            "name": "Control",
            "value": "control"
          },
          {
            "name": "Variant A",
            "value": "variant-a"
          },
          {
            "name": "Variant B",
            "value": "variant-b"
          }
        ]
      },
      {
        "component": "text",
        "valueType": "string",
        "name": "hreflang",
        "label": "Language Alternates (hreflang)",
        "description": "Comma-separated lang:url pairs e.g. en:https://site.com/home, fr:https://site.com/fr/home, x-default:https://site.com/home"
      },
      {
        "component": "select",
        "valueType": "string",
        "name": "breadcrumb",
        "label": "Breadcrumb",
        "description": "Show or hide the auto-generated breadcrumb on this page. Default is on for pages 2+ levels deep.",
        "options": [
          {
            "name": "Default (auto)",
            "value": ""
          },
          {
            "name": "Hide breadcrumb",
            "value": "false"
          }
        ]
